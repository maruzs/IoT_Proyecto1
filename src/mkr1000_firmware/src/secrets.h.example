/**
 * secrets.h.example — MKR1000 WiFi / MQTT Credentials Template
 *
 * 1. Copia este archivo a `secrets.h` en el MISMO directorio.
 * 2. Edita `secrets.h` con tus credenciales reales.
 * 3. NUNCA hagas `git add secrets.h` — ya está en `.gitignore`.
 */

#ifndef MKR1000_SECRETS_H
#define MKR1000_SECRETS_H

// ---------------------------------------------------------------------------
// WiFi
// ---------------------------------------------------------------------------
#define WIFI_SSID     "TU_WIFI_NOMBRE"
#define WIFI_PASSWORD "TU_WIFI_PASSWORD"

// ---------------------------------------------------------------------------
// MQTT Broker
// ---------------------------------------------------------------------------
#define MQTT_SERVER   "IP_DEL_BROKER"   // Ej: "192.168.1.100"
#define MQTT_PORT     8883
#define MQTT_USER     "iot_user"
#define MQTT_PASSWORD "change_me_before_deploy"

// Certificado CA en formato PEM (copiar contenido de ca.crt)
const char CA_CERT[] PROGMEM = R"EOF(
-----BEGIN CERTIFICATE-----
COLOCA_AQUI_EL_CONTENIDO_DE_TU_CA.CRT
-----END CERTIFICATE-----
)EOF";

#endif // MKR1000_SECRETS_H
