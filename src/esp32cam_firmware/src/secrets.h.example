/**
 * secrets.h.example — ESP32-CAM WiFi / MQTT Credentials Template
 *
 * 1. Copia este archivo a `secrets.h` en el MISMO directorio:
 *    cp src/esp32cam_firmware/src/secrets.h.example src/esp32cam_firmware/src/secrets.h
 * 2. Edita `secrets.h` con tus credenciales reales.
 * 3. NUNCA hagas `git add secrets.h` — ya esta en `.gitignore`.
 *
 * NOTA: ESP32-CAM usa TLS en puerto 8883 (WiFiClientSecure + setCACert).
 *       MKR1000 usa puerto 1884 sin TLS (WiFiClient).
 *       El CA cert se extrae de deploy/mosquitto/certs/ca.crt.
 */

#ifndef ESP32CAM_SECRETS_H
#define ESP32CAM_SECRETS_H

// ---------------------------------------------------------------------------
// WiFi
// ---------------------------------------------------------------------------
#define WIFI_SSID     "TU_WIFI_NOMBRE"
#define WIFI_PASSWORD "TU_WIFI_PASSWORD"

// ---------------------------------------------------------------------------
// MQTT Broker — TLS puerto 8883
// ---------------------------------------------------------------------------
// Usar MQTT_USER_ESP32CAM / MQTT_PASS_ESP32CAM del .env (T-002)
#define MQTT_SERVER   "IP_DEL_BROKER"        // Ej: "192.168.1.100"
#define MQTT_PORT     8883                    // Puerto TLS
#define MQTT_USER     "esp32cam-equipo69"
#define MQTT_PASSWORD "change_me_before_deploy"

// Certificado CA autofirmado (copiar de deploy/mosquitto/certs/ca.crt)
const char CA_CERT[] = R"EOF(
-----BEGIN CERTIFICATE-----
COLOCA_AQUI_EL_CONTENIDO_DE_TU_CA.CRT
-----END CERTIFICATE-----
)EOF";

#endif // ESP32CAM_SECRETS_H
