      "id": 1,
      "title": "Temperatura: Real vs Proyección 30min",
      "type": "timeseries",
      "datasource": {
        "type": "influxdb",
        "uid": "InfluxDB"
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "InfluxDB"
          },
          "query": "from(bucket: \"sensores\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"sensor_data\")\n  |> filter(fn: (r) => r[\"_field\"] == \"temperatura\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> keep(columns: [\"_time\", \"_value\", \"_field\"])\n  |> rename(columns: {_value: \"Temperatura Real\"})",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "influxdb",
            "uid": "InfluxDB"
          },
          "query": "from(bucket: \"sensores\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"sensor_predictions\")\n  |> filter(fn: (r) => r[\"_field\"] == \"temperatura\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> keep(columns: [\"_time\", \"_value\", \"_field\"])\n  |> rename(columns: {_value: \"Temperatura Proyectada (+30m)\"})",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineStyle": {
              "fill": "solid"
            },
            "lineWidth": 2,
            "spanNulls": false
          },
          "unit": "celsius"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Temperatura Proyectada (+30m)"
