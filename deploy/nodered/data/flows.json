        "z": "f6f2187d.f17ca8",
        "name": "Reglas de Control Automático",
        "func": "var temp = msg.payload.temperatura;\nvar gas = msg.payload.gas;\nvar gasThreshold = context.get('gas_threshold') || 1020;\nvar alertTriggered = false;\nvar alertMsg = \"\";\n\nif (temp && temp > 30) {\n    alertTriggered = true;\n    alertMsg += \"⚠️ ¡Temperatura crítica: \" + temp + \"°C!\\n\";\n}\n\nif (gas && gas > gasThreshold) {\n    alertTriggered = true;\n    alertMsg += \"🔥 ¡Alerta de Gas detectada: \" + gas + \" ppm!\\n\";\n}\n\nif (alertTriggered) {\n    var telegramMsg = {\n        payload: {\n            chatId: -1003906928304,\n            type: \"message\",\n            content: \"🚨 *[SmartHome ALERTA]*\\n\\n\" + alertMsg + \"\\n*Timestamp:* \" + new Date().toLocaleString()\n        }\n    };\n    \n    return [\n        { payload: \"ON\", topic: \"control/led\" },\n        { payload: \"ON\", topic: \"control/buzzer\" },\n        telegramMsg\n    ];\n} else {\n    return [\n        null,\n        null,\n        null\n    ];\n}",
        "outputs": 3,
        "timeout": "",
        "noerr": 0,
        "initialize": "context.set('gas_threshold', 1020);",
