    {
        "id": "rules_evaluator",
        "type": "function",
        "z": "f6f2187d.f17ca8",
        "name": "Reglas de Control Automático",
        "func": "var temp = msg.payload.temperatura;\nvar gas = msg.payload.gas;\nvar alertTriggered = false;\nvar alertMsg = \"\";\n\n// Regla 1: Temperatura alta\nif (temp && temp > 30) {\n    alertTriggered = true;\n    alertMsg += \"⚠️ ¡Temperatura crítica: \" + temp + \"°C! \";\n}\n\n// Regla 2: Gas detectado\nif (gas && gas > 400) {\n    alertTriggered = true;\n    alertMsg += \"🔥 ¡Alerta de Gas detectada: \" + gas + \" ppm!\";\n}\n\nif (alertTriggered) {\n    return [\n        { payload: \"ON\", topic: \"control/led\" },      // Activar LED\n        { payload: \"ON\", topic: \"control/buzzer\" },   // Activar Buzzer\n        { payload: alertMsg }                         // Mensaje de Telegram\n    ];\n} else {\n    return [\n        null,\n        null,\n        null\n    ];\n}",
        "outputs": 3,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 390,
        "y": 80,
        "wires": [
            [
                "mqtt_out_led"
            ],
            [
                "mqtt_out_buzzer"
            ],
            [
                "telegram_notification_trigger"
            ]
        ]
    },
