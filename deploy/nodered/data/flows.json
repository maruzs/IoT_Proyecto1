        "name": "LLM Decision Widget",
        "order": 5,
        "width": 6,
        "height": 3,
        "format": "<div ng-if=\"!msg.payload || !msg.payload.nivel\" style=\"display:flex;align-items:center;justify-content:center;height:100%;color:#999;font-style:italic;\">\n  Sin decisiones LLM\n</div>\n<div ng-if=\"msg.payload && msg.payload.nivel\" style=\"display:flex;flex-direction:column;height:100%;padding:10px;box-sizing:border-box;\">\n  <div style=\"display:flex;align-items:center;margin-bottom:8px;\">\n    <div style=\"width:20px;height:20px;border-radius:50%;background-color:{{msg.payload.color||'#0094CE'}};box-shadow:0 0 8px {{msg.payload.color||'#0094CE'}};margin-right:10px;flex-shrink:0;\"></div>\n    <span style=\"font-weight:bold;font-size:16px;text-transform:uppercase;\">{{msg.payload.nivel}}</span>\n  </div>\n  <div style=\"font-size:13px;margin-bottom:4px;line-height:1.4;\">{{msg.payload.razonamiento || '—'}}</div>\n  <div style=\"font-size:11px;color:#888;margin-top:auto;\">{{msg.payload.timestamp | date:'dd/MM/yyyy HH:mm:ss'}}</div>\n</div>",
