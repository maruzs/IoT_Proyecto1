        "id": "func_sensors_reader",
        "type": "function",
        "z": "f6f2187d.f17ca8",
        "name": "Sensors Reader",
        "func": "var temp = global.get(\"last_temp\");\nvar hum = global.get(\"last_hum\");\nvar gas = global.get(\"last_gas\");\nvar sound = global.get(\"last_sound\");\n\nif (temp === undefined || hum === undefined || gas === undefined || sound === undefined) {\n    msg.statusCode = 503;\n    msg.payload = {error: \"sensor_data_unavailable\"};\n} else {\n    msg.statusCode = 200;\n    msg.payload = {\n        temperatura: temp,\n        humedad: hum,\n        gas: gas,\n        sonido: sound\n    };\n}\nreturn msg;",
        "outputs": 1,
