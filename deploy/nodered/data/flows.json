    {
        "id": "rules_evaluator",
        "type": "function",
        "z": "f6f2187d.f17ca8",
        "name": "Reglas de Control Automático",
        "func": "var temp = msg.payload.temperatura;\nvar gas = msg.payload.gas;\nvar alertTriggered = false;\nvar alertMsg = \"\";\n\nif (temp && temp > 30) {\n    alertTriggered = true;\n    alertMsg += \"⚠️ ¡Temperatura crítica: \" + temp + \"°C!\\n\";\n}\n\nif (gas && gas > 1020) {\n    alertTriggered = true;\n    alertMsg += \"🔥 ¡Alerta de Gas detectada: \" + gas + \" ppm!\\n\";\n}\n\nif (alertTriggered) {\n    context.set(\"normal_count\", 0);\n    var telegramMsg = {\n        payload: {\n            chatId: -1003906928304,\n            type: \"message\",\n            content: \"🚨 *[SmartHome ALERTA]*\\n\\n\" + alertMsg + \"\\n*Timestamp:* \" + new Date().toLocaleString()\n        }\n    };\n    return [\n        { payload: \"ON\" },\n        telegramMsg\n    ];\n} else {\n    var count = (context.get(\"normal_count\") || 0) + 1;\n    context.set(\"normal_count\", count);\n    if (count >= 3) {\n        context.set(\"normal_count\", 0);\n        return [\n            { payload: \"OFF\" },\n            null\n        ];\n    }\n    return [null, null];\n}",
        "outputs": 2,
        "noerr": 0,
        "initialize": "context.set('normal_count', 0);",
        "finalize": "",
        "libs": [],
        "x": 390,
        "y": 80,
        "wires": [
            [
                "mqtt_out_led"
            ],
            [
                "telegram_out"
            ]
        ]
    },
