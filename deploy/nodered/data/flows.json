        "type": "function",
        "z": "f6f2187d.f17ca8",
        "name": "Store LLM Decision",
        "func": "var decision = msg.payload;\nif (decision && decision.nivel) {\n    flow.set(\"llm_decision\", decision);\n    var colors = {\n        critico: \"#ff3333\", alto: \"#ff9933\",\n        medio: \"#ffcc00\", bajo: \"#33cc33\", info: \"#0094CE\"\n    };\n    var color = colors[decision.nivel] || \"#0094CE\";\n    return [\n        { payload: {\n            nivel: decision.nivel,\n            razonamiento: decision.razonamiento || \"\",\n            accion: decision.accion || \"\",\n            timestamp: decision.timestamp || new Date().toISOString(),\n            color: color\n        }},\n        msg\n    ];\n}\nreturn [null, null];",
