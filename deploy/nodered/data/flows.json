    {
        "id": "b64_conv.001abc",
        "type": "function",
        "z": "f6f2187d.f17ca8",
        "name": "JPEG a Base64",
        "func": "if (msg.payload && msg.payload.length > 0) {\n    var base64 = msg.payload.toString('base64');\n    msg.payload = '<img src=\"data:image/jpeg;base64,' + base64 + '\" style=\"width:100%; height:auto; border:2px solid #444; border-radius:4px; object-fit:contain;\" />';\n} else {\n    msg.payload = '<div style=\"color:#888;\">Imagen vacía</div>';\n}\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 900,
