    {
        "id": "process_vision_data",
        "type": "function",
        "z": "f6f2187d.f17ca8",
        "name": "Procesar Visión",
        "func": "var human = msg.payload.human; // true / false\nvar faces = msg.payload.faces; // Array de nombres\n\nvar presenceText = human ? \"¡HUMANO DETECTADO!\" : \"Nadie en cámara\";\nvar facesText = (faces && faces.length > 0) ? faces.join(\", \") : \"Ningún rostro reconocido\";\n\nreturn [\n    { payload: presenceText },\n    { payload: facesText },\n    { payload: human ? \"#ff3333\" : \"#33cc33\" } // Color de alerta\n];",
        "outputs": 3,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 380,
        "y": 620,
        "wires": [
            [
                "ui_text_presence"
            ],
            [
                "ui_text_faces"
            ],
