    {
        "id": "func_history_parser",
        "type": "function",
        "z": "f6f2187d.f17ca8",
        "name": "CSV History Parser",
        "func": "var fs = global.get(\"fs\");\nvar path = \"/data/historial.csv\";\n\nvar fromParam = (msg.payload && msg.payload.from) || (msg.req.query && msg.req.query.from);\nvar toParam = (msg.payload && msg.payload.to) || (msg.req.query && msg.req.query.to);\nvar limitParam = (msg.payload && msg.payload.limit) || (msg.req.query && msg.req.query.limit);\n\ntry {\n    if (!fs.existsSync(path)) {\n        msg.statusCode = 503;\n        msg.payload = {error: \"historial_no_disponible\"};\n        return msg;\n    }\n    \n    var data = fs.readFileSync(path, \"utf8\");\n    var lines = data.trim().split(\"\\n\");\n    \n    if (lines.length < 2) {\n        msg.statusCode = 200;\n        msg.payload = [];\n        return msg;\n    }\n    \n    var fromTime = fromParam ? new Date(fromParam) : null;\n    var toTime = toParam ? new Date(toParam) : null;\n    var limit = parseInt(limitParam) || 100;\n    \n    var rows = [];\n    for (var i = 1; i < lines.length && rows.length < limit; i++) {\n        var cols = lines[i].split(\",\");\n        if (cols.length < 5) continue;\n        \n        var ts = new Date(cols[0]);\n        if (isNaN(ts.getTime())) continue;\n        \n        if (fromTime && ts < fromTime) continue;\n        if (toTime && ts > toTime) continue;\n        \n        rows.push({\n            timestamp: cols[0],\n            temperatura: parseFloat(cols[1]) || null,\n            humedad: parseFloat(cols[2]) || null,\n            gas: parseFloat(cols[3]) || null,\n            sensor_extra: cols[4] || null,\n            alerta: cols[5] || \"NORMAL\"\n        });\n    }\n    \n    msg.statusCode = 200;\n    msg.payload = rows;\n} catch (e) {\n    msg.statusCode = 500;\n    msg.payload = {error: \"parse_error\", details: e.message};\n}\n\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 520,
        "y": 1000,
        "wires": [
            [
                "http_res_history"
            ]
        ]
    },
    {
        "id": "func_input_validator",
        "type": "function",
        "z": "f6f2187d.f17ca8",
        "name": "Input Validator",
        "func": "function cloneMsg(p) {\n    return {\n        payload: p,\n        req: msg.req,\n        res: msg.res,\n        _msgid: msg._msgid\n    };\n}\n\nvar url = msg.req.url || msg.req.originalUrl || \"\";\nvar payload = msg.payload || {};\nvar out = [null, null, null, null, null, null, null, null];\n\nfunction sendErr(status, p) {\n    msg.statusCode = status;\n    msg.payload = p;\n    if (url.indexOf(\"led-alerta\") !== -1) out[1] = msg;\n    else if (url.indexOf(\"led-puerta\") !== -1) out[3] = msg;\n    else if (url.indexOf(\"notifications\") !== -1) out[5] = msg;\n    else if (url.indexOf(\"camera\") !== -1) out[7] = msg;\n}\n\nif (typeof payload !== 'object' || payload === null) {\n    sendErr(400, {error: \"invalid_json\"});\n    return out;\n}\n\nif (url.indexOf(\"/api/actuators/led-alerta\") !== -1) {\n    if (typeof payload.estado !== 'boolean') {\n        sendErr(422, {error: \"missing_field\", field: \"estado\"});\n        return out;\n    }\n    var st = payload.estado ? \"ON\" : \"OFF\";\n    flow.set(\"led_state\", st);\n    flow.set(\"alert_state\", st);\n    out[0] = {payload: st};\n    out[1] = cloneMsg({success: true, topic: \"smarthome/equipo69/control/led\", payload: st});\n    return out;\n}\n\nif (url.indexOf(\"/api/actuators/led-puerta\") !== -1) {\n    if (typeof payload.accion !== 'string' || (payload.accion !== \"ON\" && payload.accion !== \"OFF\")) {\n        sendErr(422, {error: \"missing_field\", field: \"accion\"});\n        return out;\n    }\n    out[2] = {payload: {accion: payload.accion}};\n    out[3] = cloneMsg({success: true, topic: \"smarthome/equipo69/control/led-puerta\"});\n    return out;\n}\n\nif (url.indexOf(\"/api/notifications\") !== -1) {\n    if (typeof payload.mensaje !== 'string' || payload.mensaje.trim() === \"\") {\n        sendErr(422, {error: \"missing_field\", field: \"mensaje\"});\n        return out;\n    }\n    out[4] = {\n        payload: {\n            chatId: -1003906928304,\n            type: \"message\",\n            content: payload.mensaje\n        }\n    };\n    out[5] = cloneMsg({success: true});\n    return out;\n}\n\nif (url.indexOf(\"/api/camera/trigger\") !== -1) {\n    var dur = payload.duracion || 5;\n    if (typeof dur !== 'number' || dur < 1) {\n        sendErr(422, {error: \"missing_field\", field: \"duracion\"});\n        return out;\n    }\n    out[6] = {payload: {accion: \"iniciar_burst\", duracion: dur}};\n    out[7] = cloneMsg({success: true, duracion: dur});\n    return out;\n}\n\nsendErr(400, {error: \"invalid_request\"});\nreturn out;",
        "outputs": 8,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
