    {
        "id": "sound_trigger",
        "type": "function",
        "z": "f6f2187d.f17ca8",
        "name": "Trigger Sonido → Cámara",
        "func": "var threshold = context.get('sound_threshold') || 600;\nvar sound = msg.payload.sensor_extra;\nif (sound !== undefined && sound > threshold) {\n    return {\n        payload: {\"accion\":\"iniciar_burst\",\"duracion\":5},\n        topic: \"smarthome/equipo69/camara/captura\"\n    };\n}\nreturn null;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "context.set('sound_threshold', 600);",
        "finalize": "",
        "libs": [],
        "x": 190,
        "y": 320,
        "wires": [
            [
                "mqtt_out_camara_captura"
            ]
        ]
    },
