        "id": "write_csv_file",
        "type": "file",
        "z": "f6f2187d.f17ca8",
        "name": "Guardar en CSV",
        "filename": "/data/historial.csv",
        "filenameType": "str",
        "appendNewline": true,
        "createDir": true,
        "overwriteFile": "false",
        "encoding": "utf8",
