    {
        "id": "csv_logging_trigger",
        "type": "function",
        "z": "f6f2187d.f17ca8",
        "name": "Formato CSV",
        "func": "var temp = msg.payload.temperatura || \"\";\nvar hum = msg.payload.humedad || \"\";\nvar gas = msg.payload.gas || \"\";\nvar sound = msg.payload.sensor_extra || \"\";\nvar alert = msg.payload.alerta || \"NORMAL\";\nvar timestamp = new Date().toISOString();\n\nmsg.payload = timestamp + \",\" + temp + \",\" + hum + \",\" + gas + \",\" + sound + \",\" + alert;\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 380,
        "y": 240,
        "wires": [
            [
                "write_csv_file"
            ]
        ]
    },
    {
        "id": "write_csv_file",
        "type": "file",
        "z": "f6f2187d.f17ca8",
        "name": "Guardar en CSV",
        "filename": "/data/historial.csv",
        "filenameType": "str",
        "appendNewline": true,
        "createDir": true,
        "overwriteFile": "false",
        "encoding": "utf8",
        "x": 620,
        "y": 340,
        "wires": [
