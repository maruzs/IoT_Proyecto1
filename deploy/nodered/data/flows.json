    {
        "id": "func_status_reader",
        "type": "function",
        "z": "f6f2187d.f17ca8",
        "name": "System Status Reader",
        "func": "var led = flow.get(\"led_state\") || \"OFF\";\nvar alert = flow.get(\"alert_state\") || \"OFF\";\n\nmsg.statusCode = 200;\nmsg.payload = {\n    led_state: led,\n    alert_state: alert,\n    caveat: \"logical state only\"\n};\nreturn msg;",
        "outputs": 1,
