        "type": "function",
        "z": "f6f2187d.f17ca8",
        "name": "Router de Comandos",
        "func": "var command = msg.payload.content || msg.payload.text;\nvar chatId = msg.payload.chatId || (msg.payload.chat && msg.payload.chat.id) || msg.chatId;\n\n// Debug de entrada en consola de Node-RED\nnode.log(\"Recibido comando: \" + command + \" de chatId: \" + chatId);\n\nif (command === \"/status\") {\n    var temp = global.get(\"last_temp\") || \"No disponible\";\n    var hum = global.get(\"last_hum\") || \"No disponible\";\n    var gas = global.get(\"last_gas\") || \"No disponible\";\n    var sound = global.get(\"last_sound\") || \"No disponible\";\n    \n    msg.payload = {\n        chatId: chatId,\n        type: \"message\",\n        content: \"📊 *SmartHome Status*\\n\\n\" +\n                 \"🌡️ *Temp:* \" + temp + \" °C\\n\" +\n                 \"💧 *Humedad:* \" + hum + \" %\\n\" +\n                 \"🔥 *Gas (MQ-2):* \" + gas + \" ppm\\n\" +\n                 \"🔊 *Sonido:* \" + sound + \"\\n\\n\" +\n                 \"*Timestamp:* \" + new Date().toLocaleString()\n    };\n    node.log(\"Respondiendo con status a: \" + chatId);\n    return [msg, null];\n} else if (command === \"/ayuda\" || command === \"/start\") {\n    msg.payload = {\n        chatId: chatId,\n        type: \"message\",\n        content: \"🤖 *SmartHome Bot*\\n\\n\" +\n                 \"Comandos disponibles:\\n\" +\n                 \"🔹 `/status` - Muestra lecturas en tiempo real\\n\" +\n                 \"🔹 `/ayuda` - Lista los comandos\\n\" +\n                 \"🔹 `/entendido` o `/noted` - Apaga el LED y Zumbador de alerta\"\n    };\n    node.log(\"Respondiendo con ayuda a: \" + chatId);\n    return [msg, null];\n} else if (command === \"/entendido\" || command === \"/noted\") {\n    // Responder en Telegram confirmando el comando\n    msg.payload = {\n        chatId: chatId,\n        type: \"message\",\n        content: \"✅ *Alerta confirmada.* Se ha enviado la orden para apagar el LED y el Zumbador de alerta.\"\n    };\n    \n    // Payload para apagar los actuadores vía MQTT\n    var actuatorMsg = {\n        payload: \"OFF\"\n    };\n    \n    node.log(\"Silenciando alertas desde Telegram a peticion de: \" + chatId);\n    return [msg, actuatorMsg];\n}\nnode.log(\"Comando desconocido ignorado.\");\nreturn null;",
