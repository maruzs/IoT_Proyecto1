    {
        "id": "parse_sensor_data",
        "type": "function",
        "z": "f6f2187d.f17ca8",
        "name": "Extraer Variables",
        "func": "var temp = msg.payload.temperatura;\nvar hum = msg.payload.humedad;\nvar gas = msg.payload.gas;\nvar sound = msg.payload.sensor_extra;\n\nglobal.set(\"last_temp\", temp);\nglobal.set(\"last_hum\", hum);\nglobal.set(\"last_gas\", gas);\nglobal.set(\"last_sound\", sound);\n\nreturn [\n    { payload: temp, topic: \"temp\" },\n    { payload: hum, topic: \"hum\" },\n    { payload: gas, topic: \"gas\" },\n    { payload: sound, topic: \"sound\" }\n];",
        "outputs": 4,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 360,
        "y": 160,
        "wires": [
            [
                "ui_gauge_temp",
                "ui_chart_temp"
            ],
            [
                "ui_gauge_hum"
            ],
            [
                "ui_gauge_gas"
            ],
