# =============================================================================
# SmartHome IoT — Variables de entorno para deploy (EJEMPLO)
# =============================================================================
# Copiá este archivo como .env y completá los valores reales.

# Token del bot de Telegram (obtenelo con @BotFather)
TELEGRAM_BOT_TOKEN=TU_API_KEY_AQUI

# Modelo LLM local (Ollama)
# Opciones recomendadas: phi3:mini (3.8B), llama3.2:3b (3B)
OLLAMA_MODEL=phi3:mini

# Zona horaria
TZ=America/Santiago
