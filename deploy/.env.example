# =============================================================================
# SmartHome IoT — Variables de entorno para deploy (EJEMPLO)
# =============================================================================
# Copia este archivo como .env y completa los valores reales:
#   cp deploy/.env.example deploy/.env
#
# ARQUITECTURA:
#   Puerto 8883 (TLS)  → backend Python, Node-RED      (servicios internos)
#   Puerto 1884 (plain) → MKR1000, ESP32-CAM            (placas embebidas)
#   Puerto 1883 (plain) → healthcheck Mosquitto (localhost only)

# Token del bot de Telegram (obtenelo con @BotFather)
TELEGRAM_BOT_TOKEN=TU_API_KEY_AQUI


# Modelo LLM local (Ollama)
# Opciones recomendadas: phi3:mini (3.8B), llama3.2:3b (3B)
OLLAMA_MODEL=phi3:mini

# ---------------------------------------------------------------------------
# MQTT Broker — 6 usuarios por cliente (T-002)
# ---------------------------------------------------------------------------
# Cada cliente tiene su propio usuario/contraseña. El broker genera el
# archivo passwd en runtime a partir de estas variables (entrypoint.sh).
# NUNCA reuses contraseñas entre clientes.
#
# Usuarios:
#   mkr1000-equipo69     → MKR1000 (sensor + actuador)
#   esp32cam-equipo69    → ESP32-CAM (camara)
#   backend-equipo69     → backend Python (acceso + camara)
#   nodered-smarthome    → Node-RED (orquestador)
#   llm-gateway-equipo69 → LLM Gateway (publica decisiones)
#   digital-twin-equipo69→ Digital Twin (estado completo)
# ---------------------------------------------------------------------------
MQTT_BROKER_IP=192.168.0.100
MQTT_PORT=8883              # puerto TLS para servicios Docker
MQTT_TLS_CA=/certs/ca.crt

MQTT_USER_MKR1000=mkr1000-equipo69
MQTT_PASS_MKR1000=change_me_before_deploy

MQTT_USER_ESP32CAM=esp32cam-equipo69
MQTT_PASS_ESP32CAM=change_me_before_deploy

MQTT_USER_BACKEND=backend-equipo69
MQTT_PASS_BACKEND=change_me_before_deploy

MQTT_USER_NODERED=nodered-smarthome
MQTT_PASS_NODERED=change_me_before_deploy

MQTT_USER_LLMGATEWAY=llm-gateway-equipo69
MQTT_PASS_LLMGATEWAY=change_me_before_deploy

MQTT_USER_DIGITALTWIN=digital-twin-equipo69
MQTT_PASS_DIGITALTWIN=change_me_before_deploy


# Zona horaria
TZ=America/Santiago

# ---------------------------------------------------------------------------
# LLM Gateway
# ---------------------------------------------------------------------------
# URL de Ollama (usa el nombre del servicio en docker-compose por defecto)
OLLAMA_URL=http://ollama:11434
OLLAMA_TIMEOUT=30
MAX_RETRIES=3
MQTT_BROKER=mosquitto
MQTT_PORT=8883
MQTT_TLS=true
MQTT_CA_CERT=/certs/ca.crt
EQUIPO_ID=equipo69

# ---------------------------------------------------------------------------
# MCP Server (T-008)
# ---------------------------------------------------------------------------
# MCP Sidecar expone tools para LangGraph (T-009) vía Streamable HTTP
MCP_NODE_RED_URL=http://nodered:1880
MCP_DIGITAL_TWIN_URL=http://digital-twin:8000
MCP_PORT=8002
