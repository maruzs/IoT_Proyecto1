# =============================================================================
# SmartHome IoT — Variables de entorno para deploy (EJEMPLO)
# =============================================================================
# Copiá este archivo como .env y completá los valores reales.

# Token del bot de Telegram (obtenelo con @BotFather)
TELEGRAM_BOT_TOKEN=TU_API_KEY_AQUI

# WiFi — red a la que se conectan MKR1000 y ESP32-CAM
WIFI_SSID=TU_WIFI
WIFI_PASSWORD=TU_CLAVE_WIFI

# MQTT Broker — credenciales TLS (usadas por Mosquitto + firmware + backend)
MQTT_BROKER_IP=192.168.0.100
MQTT_PORT=8883
MQTT_USER=iot_user
MQTT_PASSWORD=change_me_before_deploy
MQTT_TLS_CA=/certs/ca.crt

# Zona horaria
TZ=America/Santiago
