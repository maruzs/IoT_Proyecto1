# =============================================================================
# SmartHome IoT — Variables de entorno para deploy (EJEMPLO)
# =============================================================================
# Copia este archivo como .env y completa los valores reales:
#   cp deploy/.env.example deploy/.env
#
# ARQUITECTURA:
#   Puerto 8883 (TLS)  → backend Python, Node-RED      (servicios internos)
#   Puerto 1884 (plain) → MKR1000, ESP32-CAM            (placas embebidas)
#   Puerto 1883 (plain) → healthcheck Mosquitto (localhost only)

# Token del bot de Telegram (obtenelo con @BotFather)
TELEGRAM_BOT_TOKEN=TU_API_KEY_AQUI

# MQTT Broker — credenciales compartidas por placas y servicios
MQTT_BROKER_IP=192.168.0.100
MQTT_PORT=8883              # puerto TLS para servicios Docker
MQTT_USER=iot_user
MQTT_PASSWORD=change_me_before_deploy
MQTT_TLS_CA=/certs/ca.crt

# Zona horaria
TZ=America/Santiago
